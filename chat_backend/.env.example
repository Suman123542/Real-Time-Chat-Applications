PORT=5000
MONGO_URI=your_mongodb_connection_string
MONGODB_DB=chat-application
MONGODB_FORCE_DB=true
JWT_SECRET=your_jwt_secret
SHOW_DEV_OTP=false
REQUIRE_OTP_DELIVERY=true

# Used for generating links and local upload URLs
BACKEND_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:3000

# --- WebRTC (audio/video calling) ---
# For reliable calling across different networks, configure a TURN server (coturn).
# Value must be a JSON array of RTCIceServer objects:
# WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:YOUR_TURN_HOST:3478"],"username":"TURN_USER","credential":"TURN_PASS"}]
# Alternatively you can set TURN_* envs (simpler) and the backend will build the ICE list automatically:
# TURN_HOST=YOUR_TURN_HOST
# TURN_PORT=3478
# TURN_USERNAME=TURN_USER
# TURN_PASSWORD=TURN_PASS

# Set to production to disable dev OTP responses + test OTP endpoint
NODE_ENV=development

# --- Email OTP (SMTP) ---
# Example values shown for Gmail-like SMTP; use your provider's settings.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Chattrix <no-reply@yourdomain.com>"

# --- SMS OTP (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Country calling code without + (India = 91, US = 1, etc.)
SMS_COUNTRY_CODE=91
