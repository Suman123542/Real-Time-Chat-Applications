# Frontend configuration (Create React App)
#
# For multi-device testing, set these to the LAN/public URL of the ONE backend instance
# that all clients should connect to (same URL for both laptops).
#
# Example (LAN):
# REACT_APP_BACKEND_ORIGIN=http://192.168.1.10:5000
#
# You can also set these individually if needed:
# REACT_APP_API_URL=http://192.168.1.10:5000/api
# REACT_APP_SOCKET_URL=http://192.168.1.10:5000

REACT_APP_BACKEND_ORIGIN=http://localhost:5000

# WebRTC ICE servers (STUN/TURN)
# For reliable calling across different networks, you should add a TURN server (coturn).
# Value must be a JSON array.
# Example:
# REACT_APP_WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:YOUR_TURN_HOST:3478"],"username":"TURN_USER","credential":"TURN_PASS"}]

